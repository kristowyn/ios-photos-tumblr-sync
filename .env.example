TUMBLR_CONSUMER_KEY=your_consumer_key_here
TUMBLR_CONSUMER_SECRET=your_consumer_secret_here
TUMBLR_OAUTH_TOKEN=your_oauth_token_here
TUMBLR_OAUTH_SECRET=your_oauth_secret_here
TUMBLR_BLOG_NAME=yourblogname
PHOTOS_FOLDER=/path/to/exported/photos

# Optional: set this to enable AI food tag detection via Claude Vision
# If omitted, posts will be tagged with #food only
ANTHROPIC_API_KEY=your_anthropic_api_key_here
